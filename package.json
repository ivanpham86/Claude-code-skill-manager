{
  "name": "claude-skill-manager",
  "version": "1.0.0",
  "description": "GUI manager for Claude Code skills",
  "author": "Ivan Pham <ivanpham86@gmail.com>",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox\"",
    "prebuild": "node -e \"const fs=require('fs'),p=require('path');['dist','dist/handlers'].forEach(d=>{if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true})});['main.js','preload.js'].forEach(f=>fs.copyFileSync(p.join('electron',f),p.join('dist',f)));fs.readdirSync('electron/handlers').forEach(f=>fs.copyFileSync(p.join('electron/handlers',f),p.join('dist/handlers',f)))\"",
    "build": "vite build",
    "dist": "npm run prebuild && vite build && electron-builder",
    "dist:mac": "npm run prebuild && vite build && electron-builder --mac",
    "dist:win": "npm run prebuild && vite build && electron-builder --win",
    "dist:linux": "npm run prebuild && vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.ivan.claude-skill-manager",
    "productName": "Claude Skill Manager",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "dist/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@octokit/rest": "^19.0.0",
    "axios": "^1.6.0",
    "electron-is-dev": "^3.0.1",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "^8.2.0",
    "electron": "latest",
    "electron-builder": "^25.1.8",
    "typescript": "^5.0.0",
    "vite": "latest",
    "wait-on": "^7.2.0"
  }
}